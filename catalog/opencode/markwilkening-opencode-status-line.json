{
  "slug": "markwilkening-opencode-status-line",
  "name": "opencode-status-line",
  "repo": "https://github.com/markwilkening21/opencode-status-line",
  "license": "MIT",
  "redistributable": true,
  "host_clis": [
    "opencode"
  ],
  "language": "shell",
  "description": "Lightweight, fast status line for OpenCode CLI.",
  "image": {
    "url": "https://opengraph.githubassets.com/1/markwilkening21/opencode-status-line",
    "alt": "opencode-status-line repo preview",
    "source": "og-fallback",
    "local": "images/markwilkening-opencode-status-line.png"
  },
  "install": {
    "type": "git",
    "clone_dir": "markwilkening-opencode-status-line"
  },
  "configs": {
    "opencode": {
      "statusLine": {
        "type": "command",
        "command": "${INSTALL_DIR}/statusline.sh"
      }
    }
  },
  "tags": [
    "lightweight",
    "shell"
  ],
  "notes": "Verify the entry script name in the upstream repo before relying on the configured command.",
  "capabilities": {
    "network": true,
    "child_process": true,
    "filesystem_write": false,
    "env_read": [
      "HOME",
      "PATH"
    ],
    "verified_at": null,
    "verification_method": "declared"
  }
}
